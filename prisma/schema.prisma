generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String?         @unique
  emailVerified  DateTime?
  password       String?
  image          String?
  consultancy    String?
  plan           String?         @map("subscription")
  role           String          @default("user")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  favoriteBrands BrandFavorite[]
  reviews        BrandReview[]
  comments       Comment[]
  reports        Report[]
  sessions       Session[]

  @@map("users")
}

model Brand {
  id              String                @id @default(cuid())
  name            String                @unique
  category        String
  country         String
  logo            String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  favoritedBy     BrandFavorite[]
  metricsHistory  BrandMetricsHistory[]
  reviews         BrandReview[]
  forecasts       Forecast[]
  reportsAsBrand1 Report[]              @relation("Brand1")
  reportsAsBrand2 Report[]              @relation("Brand2")

  @@map("brands")
}

model BrandMetricsHistory {
  id         String   @id @default(cuid())
  brandId    String
  date       DateTime
  mentions   Int
  sentiment  Float
  popularity Float
  score      Float
  createdAt  DateTime @default(now())
  brand      Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([brandId, date])
  @@index([brandId])
  @@index([date])
  @@map("brand_metrics_history")
}

model Forecast {
  id              String    @id @default(cuid())
  brandId         String
  metricType      String
  predictedValue  Float
  confidenceLevel Float
  forecastPeriod  String
  createdAt       DateTime  @default(now())
  validatedAt     DateTime?
  actualValue     Float?
  isAccurate      Boolean?
  brand           Brand     @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@index([brandId])
  @@index([createdAt])
  @@map("forecasts")
}

model Report {
  id               String   @id @default(cuid())
  userId           String
  brand1Id         String
  brand2Id         String
  title            String
  slug             String   @unique
  executiveSummary String
  insights         String
  conclusion       String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  brand1           Brand    @relation("Brand1", fields: [brand1Id], references: [id], onDelete: Cascade)
  brand2           Brand    @relation("Brand2", fields: [brand2Id], references: [id], onDelete: Cascade)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("reports")
}

model BrandReview {
  id             String   @id @default(cuid())
  userId         String
  brandId        String
  rating         Int
  comment        String
  sentimentScore Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  brand          Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([brandId])
  @@index([rating])
  @@map("brand_reviews")
}

model Event {
  id             String   @id @default(cuid())
  name           String
  category       String
  location       String
  day            String
  month          String
  year           String
  description    String
  relevanceScore Float    @default(0)
  source         String   @default("Custom")
  isMocked       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([month])
  @@index([year])
  @@map("events")
}

model News {
  id          String    @id @default(cuid())
  title       String
  description String?
  content     String?
  url         String    @unique
  urlToImage  String?
  slug        String    @unique
  source      String?
  publishedAt DateTime?
  isFeatured  Boolean   @default(false)
  isHidden    Boolean   @default(false)
  isFallback  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comments    Comment[]

  @@index([publishedAt])
  @@index([createdAt])
  @@index([isFeatured])
  @@index([isHidden])
  @@map("news")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  newsId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  news      News     @relation(fields: [newsId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([newsId])
  @@map("comments")
}

model BrandFavorite {
  id        String   @id @default(cuid())
  userId    String
  brandId   String
  createdAt DateTime @default(now())
  brand     Brand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, brandId])
  @@index([userId])
  @@index([brandId])
  @@map("brand_favorites")
}

model NewsApiRequestLog {
  id            String   @id @default(cuid())
  timestamp     DateTime @default(now())
  success       Boolean
  brand         String?
  articlesCount Int      @default(0)

  @@index([timestamp])
  @@map("news_api_request_logs")
}
